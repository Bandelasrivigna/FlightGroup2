@{
    Layout = "_Layout";
    var session = new Group2Flight.Models.ExtensionMethods.FlightSessions(Context.Session);
    int? count = session.GetSelectedCount() ?? 0;
}
<header>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
        <div class="container-fluid">
            <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Group2Flight</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                <ul class="navbar-nav flex-grow-1">

                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Dashboard</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-controller="Search" asp-action="Index">Search</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-controller="Home" asp-action="Privacy">Privacy</a>
                    </li>
                </ul>
                 <ul class="navbar-nav ms-auto">
                    <a asp-controller="Home" asp-action="SelectedFlights"
                       class="text-white bg-black">
                        @if (count.HasValue)
                        {
                            <h5 class="p-2">
                                <span class="badge bg-light text-black">@count</span>
                            </h5>
                        }
                    </a>
                    <li class="nav-item">
                        <a class="nav-item nav-link"
                           asp-area="Admin" asp-controller="Users" asp-action="Index">Admin</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-item nav-link"
                           asp-area="Airlines" asp-controller="Flights" asp-action="Index">Airlines</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
</header>
<div>
    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success">@TempData["Message"]</div>
    }
</div>
<main role="main" class="pb-3">
    @RenderBody()
</main>